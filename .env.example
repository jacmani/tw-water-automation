# Supabase — get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key — server-only, NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Anthropic API — server-only
ANTHROPIC_API_KEY=sk-ant-...

# Optional: technician contact number shown on Template A infographic
NEXT_PUBLIC_TECHNICIAN_PHONE=+91 XXXXX XXXXX

# Shared passcode gating /committee/admin (P2-6). Client-side check, no accounts —
# matches the app's no-login philosophy. If unset, the admin page is left
# unprotected (a warning is logged to the browser console) rather than
# permanently locking the committee out. Must be a NEXT_PUBLIC_ var since it's
# checked in the browser.
NEXT_PUBLIC_ADMIN_PIN=

# Resend email alerts (Part 3)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Sandbox mode (default: true). Set to 'false' only after verifying a domain in Resend.
# In sandbox mode all emails go to jacmani@gmail.com via onboarding@resend.dev.
RESEND_SANDBOX=true

# Production sender domain (only used when RESEND_SANDBOX=false)
# Must be a verified domain in your Resend account.
RESEND_DOMAIN=yourdomain.com

# Vercel Cron authentication secret — set a random string in Vercel env vars.
# Vercel automatically sends this as "Authorization: Bearer <CRON_SECRET>" to cron routes.
CRON_SECRET=your_random_cron_secret_here

# Google Cloud Vision API key — enables parallel OCR validation to cross-check Claude extractions.
# From GCP Console → APIs & Services → Credentials → Create API key (restrict to Cloud Vision API).
# If not set, Vision validation is silently skipped. See docs/gcp-setup.md.
GOOGLE_CLOUD_VISION_API_KEY=

# ── Cost-inverted OCR engine (free-first, Haiku-on-doubt, NO Opus) ──────────────
# Which engine runs FIRST on every upload:
#   gemini → Google Gemini 2.5 Flash (FREE). Default. Anthropic only on disagreement.
#   haiku  → Claude Haiku primary (legacy paid behaviour, instant rollback switch).
EXTRACTION_PRIMARY=gemini

# Google Gemini API key — FREE tier (1,500 req/day, no card). New default primary extractor.
# Get it from https://aistudio.google.com/apikey
# IMPORTANT: keep this on a BILLING-DISABLED project — enabling billing removes the free tier.
# NOTE: Google may use free-tier requests to improve models. Water-meter readings are
# non-sensitive community data, so this is acceptable here (see CLAUDE.md RLS rationale).
# If unset, the pipeline falls back to Claude Haiku as primary (uploads never dead-end).
GEMINI_API_KEY=
# Optional: override Gemini model (default: gemini-2.5-flash)
GEMINI_MODEL=

# OpenRouter API key — FREE tier tie-breaker. Used only when Gemini + Qwen disagree,
# as a free second opinion before paying for Claude Haiku.
# Free tier: 20 RPM, 50 req/day (1,000/day forever after a one-time $10 top-up).
# Get it from https://openrouter.ai/keys . If unset, tie-breaker is skipped.
OPENROUTER_API_KEY=
# Optional: override OpenRouter model (default: qwen/qwen2.5-vl-32b-instruct:free)
OPENROUTER_MODEL=

# Optional: override the Claude escalation model (the ONLY paid model now).
# Defaults to claude-haiku-4-5-20251001. Opus has been REMOVED (5× the cost of Haiku).
EXTRACTION_MODEL=
